# CartMapper backend production environment template

APP_NAME=CartMapper API
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=10000

# Frontend domain(s)
FRONTEND_URL=https://your-site.netlify.app
ALLOWED_ORIGINS=["https://your-site.netlify.app"]

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=https://your-site.netlify.app/auth/callback

# LLM
GROQ_API_KEY=replace-with-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
ENABLE_RAG=false

# Azure Speech (optional, recommended for better Odia accent)
AZURE_SPEECH_KEY=replace-with-azure-speech-key
AZURE_SPEECH_REGION=replace-with-azure-region
AZURE_ODIA_VOICE=or-IN-SubhasiniNeural
AZURE_USE_FOR_ODIA_ONLY=true
AZURE_TTS_OUTPUT_FORMAT=audio-24khz-48kbitrate-mono-mp3

# Persistent storage (Render disk)
CHROMA_PERSIST_DIR=/var/data/chroma_db
CHROMA_COLLECTION_NAME=cartmapper-rag

UPLOAD_DIR=/var/data/uploads
QR_UPLOAD_DIR=/var/data/uploads/qr
AUDIO_UPLOAD_DIR=/var/data/uploads/audio
DOCUMENT_UPLOAD_DIR=/var/data/uploads/documents

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional defaults
DEFAULT_SOURCE_LANG=auto
DEFAULT_TARGET_LANG=en
